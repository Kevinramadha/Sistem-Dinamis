{UTF-8}
Air Limbah Awal=1.48e+08
	~	m³/tahun
	~		|

Akumulasi Polusi= INTEG (Produksi Air Limbah+Produksi Limbah Padat-Peluruhan Polusi Alami\
		-Pengolahan Limbah,
		0.174)
	~	dimensionless
	~		|

Angkatan Kerja=Populasi Penduduk DIY * Labour Force Fraction
	~	jiwa
	~		|

Area Destinasi Wisata=318.6
	~	ha
	~		|

Carrying Capacity per ha=142.4
	~	wisatawan/ha
	~		|

Clean Water from Rainfall=Jumlah Keluarga * Rainfall Collection per Household
	~	m³/tahun
	~		|

Crowding Index=(Jumlah Wisatawan Nusantara + Jumlah Wisatawan Mancanegara) / (Area Destinasi Wisata\
		 * Carrying Capacity per ha)
	~	dimensionless
	~		|

Decay Rate=0.1
	~	1/tahun
	~	Laju Peluruhan
	|

Demolisi Akomodasi=Jumlah Unit Akomodasi / Umur Akomodasi Hotel Lifespan
	~	Unit/tahun
	~		|

Effect of Crowding on Tourism=WITH LOOKUP(Crowding Index,
	([(0,0)-(20000,1.5)],(0,0.8),(5000,1),(10000,0.95),(15000,0.85),(20000,0.8)))
	~	dimensionless
	~		|

Effect of Labour Jobs on Immigration = WITH LOOKUP (Rasio Pengangguran,
		([(0,0)-(25,1.5)],(0,0.8), (1,1), (5,1.2), (10,1.3), (15,1.3), (25,1.3)))
	~	dimensionless
	~		|

Effect of Land Availability on Construction=WITH LOOKUP(Land Used Fraction,
	([(0,0)-(1,1)],(0,1),(0.2,0.95),(0.4,0.85),
	(0.6,0.7),(0.8,0.55),(0.9,0.5),(1,0.5)))
	~	dimensionless
	~		|

Effect of Natural Beauty on Tourism = WITH LOOKUP (Natural Beauty Index,
		([(0,0)-(2,1.5)],(0,0.2),(0.5,0.5),(0.8,0.8),(1,1),(1.2,1.2)))
	~	dimensionless
	~		|

Effect of Pollution on Death Rate = WITH LOOKUP (Indeks Polusi Gabungan,
		([(0,0)-(10,1.5)],(0,1), (0.5,1), (1,1), (1.5,1.1), (2,1.2), (3,1.35), (10,1.4)))
	~	dimensionless
	~		|

Effect of Pollution on Tourism = WITH LOOKUP (Indeks Polusi Gabungan,
		([(0,0)-(4,1.5)],(0,1.2), (0.5,1.1), (1,1), (1.5,0.9), (2,0.85), (3,0.8), (4,0.8)))
	~	dimensionless
	~		|

Effect of Room Demand on Construction = WITH LOOKUP (Room Demand Ratio,
		([(0,0)-(15,1.5)],(0,0.6), (0.5,0.7), (1,1), (1.5,1.3), (2,1.4), (10,1.4), (15,1.4)\
		))
	~	dimensionless
	~		|

Effect of Vegetation Cover on Infiltration=WITH LOOKUP(Vegetation Cover Ratio,
	([(0,0)-(1.5,1.5)],(0,0.8),(0.5,0.9),
	(1,1),(1.2,1)))
	~	dimensionless
	~		|

Effect of Water Availability on Tourism = WITH LOOKUP ("Rasio Demand-Supply Air",
		([(0,0)-(20,1.5)],(0,1.2), (1,1), (5,0.85), (10,0.8), (20,0.8), (30,0.8)))
	~	dimensionless
	~	Saat supply lebih besar dari demand (rasio < 1), multiplier > 1 sehingga \
		sektor pariwisata meningkat. Sebaliknya, saat terjadi kekurangan air \
		(rasio > 1), nilai multiplier menurun.
	|

Ekstraksi Air Tanah=MIN(Kebutuhan Air Total, Ekstraksi Air Tanah yang Diizinkan)
	~	m³/tahun
	~		|

Ekstraksi Air Tanah yang Diizinkan=4e+07
	~	m³/tahun
	~		|

Emigrasi=Populasi Penduduk DIY * Tingkat Emigrasi
	~	jiwa/tahun
	~		|

Fraksi Air Limbah=0.8
	~	dimensionless
	~		|

Hari per Tahun=365
	~	hari
	~		|

Imbuhan Air Tanah=Normal Infiltration Rate * Effect of Vegetation Cover on Infiltration
	~	m³/tahun
	~		|

Imigrasi=Populasi Penduduk DIY * Tingkat Imigrasi Dasar * Effect of Labour Jobs on Immigration
	~	jiwa/tahun
	~		|

Indeks Kualitas Lingkungan=1 / (1 + Akumulasi Polusi)
	~	dimensionless
	~		~	:SUPPLEMENTARY 
	|

Indeks Polusi Air=Kebutuhan Air Total * Fraksi Air Limbah * (1 - Proporsi Pengolahan Air Limbah\
		) / Air Limbah Awal
	~	dimensionless
	~	32700000 -> initial value 2024 utk air limbah 2024
	|

Indeks Polusi Gabungan=0.6 * Indeks Polusi Air + 0.4 * Indeks Polusi Padat
	~	dimensionless
	~		|

Indeks Polusi Padat=(Limbah Padat Hotel + Limbah Padat Domestik) * (1 - Proporsi Pengolahan Limbah Padat\
		) / Limbah Padat Awal
	~	dimensionless
	~	670000 -> initian value limbah padat 2024
	|

Jobs per Room=0.75
	~	jiwa/kamar
	~		|

